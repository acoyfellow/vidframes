{
  "name": "vidframes",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Cost-aware video frame extraction, vision analysis, and audio transcription via Workers AI",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "vidframes": "src/cli.ts"
  },
  "scripts": {
    "cli": "bun run src/cli.ts",
    "dev": "vite --host 127.0.0.1 --port 5374",
    "dev:worker": "wrangler dev --local --port 4783",
    "build": "vite build && wrangler deploy --dry-run --outdir dist/worker",
    "deploy": "vite build && wrangler deploy",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20260525.0",
    "@types/bun": "^1.3.14",
    "typescript": "^5.7.3",
    "vite": "^7.3.3",
    "wrangler": "^4.82.1"
  }
}
